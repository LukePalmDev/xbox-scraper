    },
    {
      "name": "Scraper (Xbox One)",
      "runtimeExecutable": "python3",
      "runtimeArgs": ["fetch_xbox_og.py", "--category", "fullXboxOne", "--batch", "20", "--delay", "0.5", "--json-out", "games.json"],
      "port": 0
    },
    {
      "name": "BigId Discovery",
      "runtimeExecutable": "python3",
